{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
    },
    required: ["openai_api_key"],
    additionalProperties: false,
  },

  slots: {},

  program: {
    image: "ghcr.io/theycallmemax/agentx-tau2-purple:latest",
    entrypoint: "uv run src/server.py --host 0.0.0.0 --port 9009",

    env: {
      OPENAI_API_KEY: "${config.openai_api_key}",
      TAU2_AGENT_LLM: "openai/gpt-5-mini",
      TAU2_AGENT_TEMPERATURE: "0",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
